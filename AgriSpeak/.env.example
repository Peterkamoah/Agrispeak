# Global setup — copy to `.env` and fill in secrets (see README)

PORT=3000
NODE_ENV=development

# Google Gemini
GOOGLE_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Khaya Translation API — https://translation.ghananlp.org/
KHAYA_TRANSLATION_KEY=your_khaya_translation_key_here
KHAYA_TRANSLATION_URL=https://translation-api.ghananlp.org/v1/translate

# Khaya ASR (Speech-to-Text) API
KHAYA_ASR_KEY=your_khaya_asr_key_here
KHAYA_ASR_URL=https://translation-api.ghananlp.org/asr/v1/transcribe

PROJECT_NAME=Agrispeak
DEFAULT_LANGUAGE=twi

# Frontend (Vite) — must be prefixed with VITE_
VITE_API_URL=http://localhost:3000/api
VITE_PROJECT_NAME=Agrispeak
VITE_DEFAULT_LANGUAGE=tw
